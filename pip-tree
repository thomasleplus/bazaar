#!/bin/bash
# Displays the full dependency tree for packages listed in requirements.txt
# Creates a temporary virtual environment, installs dependencies, and runs pipdeptree

set -euo pipefail
IFS=$'\n\t'

\python3 -m venv /tmp/dep-tree-env
# shellcheck source=/dev/null
source /tmp/dep-tree-env/bin/activate
\pip install -r requirements.txt
\pipdeptree -fl
deactivate
\rm -rf /tmp/dep-tree-env
